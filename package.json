{
  "name": "tradeflow",
  "version": "0.1.0",
  "description": "Enterprise AI-Powered Global B2B/B2C Import-Export Marketplace",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "test": "jest",
    "db:setup": "psql -U postgres -c 'CREATE DATABASE tradeflow;' && psql -U postgres -d tradeflow -f packages/database/schema.sql",
    "db:migrate": "psql -U postgres -d tradeflow -f packages/database/migrations/001_init.sql",
    "db:seed": "psql -U postgres -d tradeflow -f packages/database/seeds.sql",
    "db:reset": "psql -U postgres -d tradeflow -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "next": "^14.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "@supabase/supabase-js": "^2.38.4",
    "zustand": "^4.4.6",
    "tailwindcss": "^3.3.6",
    "framer-motion": "^10.16.4",
    "axios": "^1.6.2",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.22.4",
    "react-hook-form": "^7.48.0",
    "react-hot-toast": "^2.4.1",
    "date-fns": "^2.30.0",
    "recharts": "^2.10.3",
    "react-icons": "^4.12.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.2.1",
    "stripe": "^13.10.0",
    "js-cookie": "^3.0.5",
    "next-intl": "^2.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/js-cookie": "^3.0.6",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.1.5"
  }
}
